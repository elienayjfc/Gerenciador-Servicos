<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="440.0" prefWidth="752.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.jrc.gerenciador.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
 <AnchorPane id="principal" focusTraversable="true" maxHeight="-1.0" maxWidth="-1.0" prefHeight="-1.0" prefWidth="-1.0">
   <children>
         <Button id="newCliente" fx:id="newCliente" layoutX="66.0" layoutY="-20.0" mnemonicParsing="false" onAction="#clicar" prefHeight="41.0" prefWidth="135.0" text="Novo Cliente" underline="true">
            <font>
               <Font name="Goldman Regular" size="12.0" />
            </font>
         </Button>
         <Button id="financeiro" fx:id="financeiro" layoutX="355.0" layoutY="-20.0" mnemonicParsing="false" onAction="#abrirFinanceiro" prefHeight="41.0" prefWidth="135.0" text="Financeiro" underline="true" wrapText="true">
            <font>
               <Font name="Goldman Regular" size="12.0" />
            </font>
         </Button>
         <Button id="newAtendimento" fx:id="orcamento" layoutX="214.0" layoutY="-20.0" mnemonicParsing="false" onAction="#AbrirOrc" prefHeight="41.0" prefWidth="135.0" text="Orçamento" underline="true">
            <font>
               <Font name="Goldman Regular" size="12.0" />
            </font>
         </Button>
         <Button id="nfe" fx:id="nfe" layoutX="498.0" layoutY="-20.0" mnemonicParsing="false" prefHeight="41.0" prefWidth="135.0" text="NF-E" underline="true">
            <font>
               <Font name="Goldman Regular" size="12.0" />
            </font>
         </Button>
         <TableView id="table" fx:id="tabelaClientes" editable="true" layoutX="59.0" layoutY="40.0" prefHeight="260.0" prefWidth="594.0">
           <columns>
             <TableColumn id="tabelaClientes" prefWidth="161.0" text="Cliente" />
             <TableColumn minWidth="0.0" prefWidth="180.0" text="Endereço" />
               <TableColumn prefWidth="89.0" text="Valor" />
               <TableColumn prefWidth="119.0" text="Status" />
           </columns>
            <opaqueInsets>
               <Insets />
            </opaqueInsets>
         </TableView>
   </children>
 </AnchorPane>
   <Button id="exit" fx:id="exit" cancelButton="true" mnemonicParsing="false" onAction="#sair" prefHeight="48.0" prefWidth="80.0" style="-fx-background-color: red;" text="Sair" textFill="WHITE">
      <font>
         <Font name="System Bold" size="17.0" />
      </font>
   </Button>
</VBox>
